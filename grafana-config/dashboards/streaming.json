{
  "title": "Clúster Big Data — Streaming en Tiempo Real",
  "uid": "bigdata-streaming-v2",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "2s",
  "timepicker": {
    "refresh_intervals": ["1s", "2s", "5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Revenue por Producto por Minuto",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT ventana_inicio AS time, product AS metric, revenue AS value FROM ventas_por_minuto ORDER BY ventana_inicio",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Revenue Total Acumulado",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT SUM(revenue) AS revenue FROM ventas_por_minuto",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total de Compras",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT SUM(total_compras) AS compras FROM ventas_por_minuto",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Eventos por Tipo (últimas ventanas)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "tipo",
        "orientation": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT tipo, SUM(total_eventos) AS total_eventos FROM eventos_por_tipo GROUP BY tipo ORDER BY total_eventos DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top Productos por Revenue",
      "type": "table",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "revenue" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "revenue", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT product AS producto, SUM(total_compras) AS compras, SUM(revenue) AS revenue FROM ventas_por_minuto GROUP BY product ORDER BY revenue DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Eventos por Tipo en el Tiempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT ventana_inicio AS time, tipo AS metric, total_eventos AS value FROM eventos_por_tipo ORDER BY ventana_inicio",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Funnel de Conversión",
      "description": "Solo disponible con datos de la tienda web (no del simulador)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "tipo",
        "orientation": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT tipo, SUM(total_eventos) AS total FROM eventos_por_tipo WHERE tipo IN ('page_view','product_hover','add_to_cart','purchase') GROUP BY tipo ORDER BY total DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Productos más Visitados (Hover)",
      "description": "Solo disponible con datos de la tienda web (no del simulador)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "producto",
        "orientation": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT product AS producto, SUM(total) AS vistas FROM actividad_productos WHERE tipo = 'product_hover' GROUP BY product ORDER BY vistas DESC LIMIT 8",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Navegadores",
      "description": "Solo disponible con datos de la tienda web (no del simulador)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "browser",
        "orientation": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT browser, SUM(total_eventos) AS total FROM sesiones_navegadores GROUP BY browser ORDER BY total DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Sistemas Operativos",
      "description": "Solo disponible con datos de la tienda web (no del simulador)",
      "type": "barchart",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "os",
        "orientation": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT os, SUM(total_eventos) AS total FROM sesiones_navegadores GROUP BY os ORDER BY total DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Estudiantes Conectados",
      "description": "IP, browser y OS de cada estudiante. Solo disponible con datos de la tienda web.",
      "type": "table",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-streaming" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } }
      },
      "options": { "sortBy": [{ "displayName": "total", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-streaming" },
          "rawSql": "SELECT ip, browser, os, SUM(total_eventos) AS total FROM sesiones_navegadores GROUP BY ip, browser, os ORDER BY total DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
